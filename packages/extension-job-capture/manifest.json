{
  "manifest_version": 3,
  "minimum_chrome_version": "88",
  "name": "TalentOS Job Capture",
  "version": "0.2.0",
  "description": "Save job postings to TalentOS",
  "permissions": ["activeTab", "storage", "scripting"],
  "action": {
    "default_title": "Save to TalentOS",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
